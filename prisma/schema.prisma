generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id      String  @id @default(uuid())
  nombre  String
  email   String  @unique
  role    Role    @default(MIEMBRO)
  foto    String?
  member  Member?
}

model Member {
  id                  String           @id
  user                User             @relation(fields: [id], references: [id])
  fechaRegistro       DateTime         @default(now())
  fechaVencimiento    DateTime
  planId              String
  plan                Plan             @relation(fields: [planId], references: [id])
  status              MembershipStatus @default(PENDIENTE)
  deuda               Float            @default(0)
  fechaNacimiento     DateTime?
  contactoEmergencia  String?
  telefonoEmergencia  String?
  objetivo            String?
  notas               String?
  ultimaAsistencia    DateTime?
  rachaDias           Int              @default(0)
  attendance          Attendance[]
  transactions        Transaction[]
  metrics             BodyMetrics[]
  appointments        Appointment[]
}

model Plan {
  id            String   @id @default(uuid())
  nombre        String
  costo         Float
  duracionMeses Int
  beneficios    String[]
  color         String?
  members       Member[]
}

model Attendance {
  id        String   @id @default(uuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  entrada   DateTime @default(now())
}

model Transaction {
  id        String   @id @default(uuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  monto     Float
  fecha     DateTime @default(now())
  metodo    String
  tipo      String
  status    String
}

model BodyMetrics {
  id            String   @id @default(uuid())
  memberId      String
  member        Member   @relation(fields: [memberId], references: [id])
  fecha         DateTime @default(now())
  peso          Float
  masaMuscular  Float
  grasaCorporal Float
  agua          Float
  imc           Float
}

model Appointment {
  id        String   @id @default(uuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  fecha     DateTime
  hora      String
  status    String
  notas     String?
}

enum Role {
  SUPER_ADMIN
  ADMIN
  INSTRUCTOR
  MIEMBRO
  NUTRIOLOGO
}

enum MembershipStatus {
  ACTIVO
  VENCIDO
  PENDIENTE
}
