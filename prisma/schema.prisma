generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  nombre   String
  email    String  @unique
  telefono String? @unique
  role     Role    @default(MIEMBRO)
  foto     String?
  password String?
  member   Member?
}

model Member {
  id                 String           @id
  fechaRegistro      DateTime         @default(now())
  fechaVencimiento   DateTime
  planId             String
  status             MembershipStatus @default(PENDIENTE)
  deuda              Float            @default(0)
  fechaNacimiento    DateTime?
  contactoEmergencia String?
  telefonoEmergencia String?
  objetivo           String?
  notas              String?
  ultimaAsistencia   DateTime?
  rachaDias          Int              @default(0)
  puntosComunidad    Int              @default(0)
  conectadoApple     Boolean          @default(false)
  conectadoGoogle    Boolean          @default(false)
  pushEnabled        Boolean          @default(true)
  logros             String[]         @default([])
  appointments       Appointment[]
  attendance         Attendance[]
  metrics            BodyMetrics[]
  user               User             @relation(fields: [id], references: [id])
  plan               Plan             @relation(fields: [planId], references: [id])
  transactions       Transaction[]
  routines           Routine[]
}

model Plan {
  id            String   @id @default(uuid())
  nombre        String
  costo         Float
  duracionMeses Int
  beneficios    String[]
  color         String?
  members       Member[]
}

model Attendance {
  id       String    @id @default(uuid())
  memberId String
  entrada  DateTime  @default(now())
  salida   DateTime?
  member   Member    @relation(fields: [memberId], references: [id])
}

model Transaction {
  id       String   @id @default(uuid())
  memberId String
  monto    Float
  fecha    DateTime @default(now())
  metodo   String
  tipo     String
  status   String
  member   Member   @relation(fields: [memberId], references: [id])
}

model BodyMetrics {
  id            String   @id @default(uuid())
  memberId      String
  fecha         DateTime @default(now())
  peso          Float
  masaMuscular  Float
  grasaCorporal Float
  agua          Float
  imc           Float
  member        Member   @relation(fields: [memberId], references: [id])
}

model Appointment {
  id       String   @id @default(uuid())
  memberId String
  fecha    DateTime
  hora     String
  status   String
  notas    String?
  member   Member   @relation(fields: [memberId], references: [id])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  INSTRUCTOR
  MIEMBRO
  NUTRIOLOGO
}

enum MembershipStatus {
  ACTIVO
  VENCIDO
  PENDIENTE
}

model Routine {
  id          String     @id @default(uuid())
  memberId    String
  nombre      String
  descripcion String?
  fecha       DateTime   @default(now())
  instructor  String?
  objetivo    String?
  exercises   Exercise[]
  member      Member     @relation(fields: [memberId], references: [id])
}

model Exercise {
  id        String  @id @default(uuid())
  routineId String
  nombre    String
  series    Int
  reps      String
  descanso  String?
  notas     String?
  videoUrl  String?
  routine   Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id               String  @id @default("default")
  gymName          String  @default("GymMaster Pro")
  aforoMaximo      Int     @default(50)
  direccion        String?
  horario          String?
  wahaUrl          String?
  wahaKey          String?
  geminiKey        String?
  ycloudKey        String? @map("ycloud_key")
  pushEnabled      Boolean @default(true)
  backupEnabled    Boolean @default(true)
}
